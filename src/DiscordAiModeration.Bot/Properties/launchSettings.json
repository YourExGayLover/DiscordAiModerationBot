{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "DiscordAiModeration.Bot": {
      "commandName": "Project",
      "environmentVariables": {
        "AI_PROVIDER": "ollama",
        "OLLAMA_BASE_URL": "http://localhost:11434",
        "OLLAMA_MODEL": "llama3.1:8b",
        "SQLITE_PATH": "botdata.db",

        "AI_DEBUG_LOGGING": "false",
        "AI_LOG_PROMPTS": "false",
        "AI_LOG_RESPONSES": "false",
        "AI_LOG_MAX_BODY_LENGTH": "1000",

        "Logging__LogLevel__Default": "Warning",
        "Logging__LogLevel__Microsoft": "Warning",
        "Logging__LogLevel__System": "Warning",
        "Logging__LogLevel__System.Net.Http.HttpClient": "Warning",
        "Logging__LogLevel__DiscordAiModeration": "Warning",

        "Debug__EnableDashboard": "false"
      }
    }
  }
}
