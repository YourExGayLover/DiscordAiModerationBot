{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "DiscordAiModeration.Bot": {
      "commandName": "Project",
      "environmentVariables": {
        "AI_PROVIDER": "ollama",
        "OLLAMA_BASE_URL": "http://localhost:11434",
        "OLLAMA_MODEL": "llama3.1:8b",
        "SQLITE_PATH": "botdata.db",
        "BOT_LOG_LEVEL": "Debug",
        "AI_DEBUG_LOGGING": "true",
        "AI_LOG_PROMPTS": "true",
        "AI_LOG_RESPONSES": "true",
        "AI_LOG_MAX_BODY_LENGTH": "4000"
      }
    }
  }
}